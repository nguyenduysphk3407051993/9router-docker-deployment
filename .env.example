# ========= Port / timezone =========
NINE_ROUTER_PORT=20128
TZ=Asia/Ho_Chi_Minh

# ========= Required secrets (change in production) =========
JWT_SECRET=replace-with-long-random-secret
INITIAL_PASSWORD=replace-with-strong-password
API_KEY_SECRET=replace-with-random-api-key-secret
MACHINE_ID_SALT=replace-with-random-machine-id-salt

# ========= Security =========
REQUIRE_API_KEY=true
AUTH_COOKIE_SECURE=false

# ========= Runtime flags =========
ENABLE_REQUEST_LOGS=false
OBSERVABILITY_ENABLED=true

# ========= URL contract =========
# Internal URL used by 9router background jobs in Docker network
BASE_URL=http://9router:20128
# Public/client URL used by browser & tools on host machine
NEXT_PUBLIC_BASE_URL=http://127.0.0.1:20128

CLOUD_URL=https://9router.com
NEXT_PUBLIC_CLOUD_URL=https://9router.com

# ========= Docker network shared with OpenClaw =========
DOCKER_SHARED_NETWORK=ai_stack

# Keep local endpoints out of proxies
NO_PROXY=localhost,127.0.0.1,9router
